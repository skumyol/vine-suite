# Vine API Deployment Configuration
# Copy to .env and fill in your actual API keys

# =============================================================================
# VLM Providers (Required for pipeline evaluation with VLM verification)
# =============================================================================

# OpenRouter API key (recommended - supports GPT-4V, Claude, etc.)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# NVIDIA API key (optional - alternative VLM provider)
NVIDIA_API_KEY=nvapi-your-key-here

# =============================================================================
# OCR Service Configuration (optional overrides)
# =============================================================================

# Which OCR engines to enable (comma-separated)
# ARM64 (Apple Silicon): easyocr,tesseract
# x86_64 (Linux servers): easyocr,tesseract,paddle
# ENABLED_ENGINES=easyocr,tesseract

# Maximum concurrent OCR requests (memory optimization)
# MAX_CONCURRENT_REQUESTS=3

# Run garbage collection after each request
# GC_AFTER_REQUEST=true

# OCR operation timeout (seconds)
# OCR_TIMEOUT=30

# =============================================================================
# Service URLs (for local development)
# =============================================================================

# These are set automatically in docker-compose.yml
# OCR_SERVICE_URL=http://ocr-service:8000
# OPENSERP_URL=http://openserp:7000

# =============================================================================
# Example: Full Production .env
# =============================================================================
# OPENROUTER_API_KEY=sk-or-v1-xxx...
# NVIDIA_API_KEY=nvapi-xxx...
# ENABLED_ENGINES=easyocr,tesseract,paddle
